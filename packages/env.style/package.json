{
	"name": "env.style",
	"version": "1.0.1",
	"description": "Environment-tinted favicons for Next.js, Vite, and Waku — see at a glance whether a tab is dev, preview, staging, or production.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/QuadDepo/env.style.git",
		"directory": "packages/env.style"
	},
	"homepage": "https://github.com/QuadDepo/env.style/tree/main/packages/env.style#readme",
	"bugs": "https://github.com/QuadDepo/env.style/issues",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./manifest": {
			"import": {
				"types": "./dist/manifest.d.ts",
				"default": "./dist/manifest.js"
			},
			"require": {
				"types": "./dist/manifest.d.cts",
				"default": "./dist/manifest.cjs"
			}
		},
		"./vite": {
			"import": {
				"types": "./dist/vite.d.ts",
				"default": "./dist/vite.js"
			},
			"require": {
				"types": "./dist/vite.d.cts",
				"default": "./dist/vite.cjs"
			}
		},
		"./tanstack-start": {
			"import": {
				"types": "./dist/tanstack-start.d.ts",
				"default": "./dist/tanstack-start.js"
			},
			"require": {
				"types": "./dist/tanstack-start.d.cts",
				"default": "./dist/tanstack-start.cjs"
			}
		},
		"./waku": {
			"import": {
				"types": "./dist/waku.d.ts",
				"default": "./dist/waku.js"
			},
			"require": {
				"types": "./dist/waku.d.cts",
				"default": "./dist/waku.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=18.17.0"
	},
	"scripts": {
		"build": "tsup src/index.ts src/vite.ts src/tanstack-start.ts src/waku.ts src/manifest.ts --format esm,cjs --dts",
		"prepublishOnly": "pnpm build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"format": "biome format --write .",
		"lint": "biome check ."
	},
	"keywords": [
		"nextjs",
		"vite",
		"vite-plugin",
		"waku",
		"favicon",
		"environment",
		"dx",
		"staging",
		"preview"
	],
	"dependencies": {
		"decode-ico": "^0.4.1",
		"sharp": "^0.35.3"
	},
	"peerDependencies": {
		"next": ">=13",
		"react": ">=19",
		"vite": ">=5"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"vite": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"next": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tsup": "^8.5.1",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "^4.1.9"
	}
}
